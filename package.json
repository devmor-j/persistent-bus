{
  "name": "persistent-bus",
  "version": "0.1.1",
  "scripts": {
    "build": "tsdown",
    "dev": "npm run build; clear; node ./test/sample.ts",
    "test": "bash scripts/test.sh",
    "test:coverage": "npx lcov-badge2 coverage/lcov.info -o coverage.svg",
    "prettier": "npx prettier -wu './(src|test)/**/*.{js,cjs,mjs,ts,cts,mts,json,yml,md}'"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "~1.75.1",
    "@types/node": "~26.0.0",
    "c8": "~11.0.0",
    "lcov-badge2": "~1.1.4",
    "prettier": "~3.8.4",
    "prettier-plugin-organize-imports": "~4.3.0",
    "redis": "~6.0.0",
    "tsdown": "~0.22.3",
    "typescript": "~6.0.3"
  },
  "type": "module",
  "private": false,
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.mts",
        "default": "./dist/main.mjs"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "event-bus",
    "pub-sub",
    "outbox-pattern",
    "at-least-once",
    "reliable-messaging",
    "redis",
    "sqlite",
    "typescript",
    "nodejs",
    "dead-letter"
  ],
  "description": "🚌 Persistent event bus with at-least-once delivery via SQLite + Redis, Fully typed.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devmor-j/persistent-bus.git"
  },
  "homepage": "https://github.com/devmor-j/persistent-bus#readme",
  "bugs": {
    "url": "https://github.com/devmor-j/persistent-bus/issues"
  },
  "engines": {
    "node": ">=22.5"
  },
  "author": "Morteza Jamshidi",
  "license": "MIT"
}
