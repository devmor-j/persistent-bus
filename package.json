{
  "name": "persistent-bus",
  "version": "0.0.0",
  "scripts": {
    "build": "tsdown",
    "dev": "npm run build; clear; node ./test/sample.ts",
    "prisma:generate": "npx prisma generate --config ./src/prisma/prisma.config.ts",
    "prisma:studio": "npx prisma studio --config ./src/prisma/prisma.config.ts",
    "prisma:migrate": "npx prisma migrate dev --config ./src/prisma/prisma.config.ts",
    "prisma:push": "npx prisma db push --config ./src/prisma/prisma.config.ts",
    "prisma:reset": "npx prisma migrate reset --config ./src/prisma/prisma.config.ts",
    "prettier": "npx prettier -wu './src/**/*.{js,cjs,mjs,ts,cts,mts,json,yml,md}'"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "~7.8.0",
    "@prisma/adapter-pg": "~7.8.0",
    "@prisma/client": "~7.8.0",
    "pg": "~8.21.0",
    "prisma": "~7.8.0",
    "redis": "~6.0.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "~1.73.1",
    "@types/node": "~25.9.3",
    "@types/pg": "~8.20.0",
    "prettier": "~3.8.4",
    "prettier-plugin-organize-imports": "~4.3.0",
    "tsdown": "~0.22.3",
    "typescript": "~6.0.3"
  },
  "allowScripts": {
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "better-sqlite3@12.11.1": true
  },
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./dist/main.mjs",
  "types": "./dist/main.d.mts",
  "exports": {
    ".": {
      "require": "./dist/main.cjs",
      "import": "./dist/main.mjs",
      "types": "./dist/main.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "nodejs",
    "persistent-bus"
  ],
  "description": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devmor-j/persistent-bus.git"
  },
  "homepage": "https://github.com/devmor-j/persistent-bus#readme",
  "bugs": {
    "url": "https://github.com/devmor-j/persistent-bus/issues"
  },
  "engines": {
    "node": ">=18.12"
  },
  "author": "Morteza Jamshidi",
  "license": "MIT"
}
