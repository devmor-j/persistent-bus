{
  "include": ["./src", "./test", "./test/sample.ts", "./test/benchmark.ts"],
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023"],
    "types": ["./processEnv.d.ts", "node"],
    "module": "nodenext",
    "rootDir": ".",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "importHelpers": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "allowJs": true
  }
}
